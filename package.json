{
  "name": "@coralswap/sdk",
  "version": "x.1.0",
  "description": "TypeScript SDK for CoralSwap -- contract-first AMM on Stellar/Soroban",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist/**/*"
  ],
  "scripts": {
    "build": "tsc",
    "build:watch": "tsc --watch",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "test:integration": "jest --config jest.integration.config.js",
    "test:integration:portfolio": "jest --config jest.integration.config.js --testPathPattern=portfolio.integration",
    "lint": "eslint src/**/*.ts",
    "lint:fix": "eslint src/**/*.ts --fix",
    "clean": "rimraf dist",
    "prepare": "npm run build",
    "prepublishOnly": "npm test && npm run lint",
    "examples:simple-swap": "ts-node examples/simple-swap.ts",
    "examples:provide-liquidity": "ts-node examples/provide-liquidity.ts",
    "examples:read-reserves": "ts-node examples/read-reserves.ts",
    "examples:rwa-pool": "ts-node examples/rwa-pool.ts",
    "examples:governance-vote": "ts-node examples/governance-vote.ts",
    "docs": "typedoc",
    "fuzz": "jest --testPathPattern=fuzz --no-coverage",
    "benchmark": "ts-node benchmarks/run.ts"
  },
  "keywords": [
    "coralswap",
    "stellar",
    "soroban",
    "dex",
    "defi",
    "amm",
    "sdk",
    "typescript"
  ],
  "author": "CoralSwap Finance",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/CoralSwap-Finance/coralswap-sdk.git"
  },
  "dependencies": {
    "@stellar/stellar-sdk": "^12.3.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/jest": "^29.5.0",
    "@types/node": "^22.0.0",
    "@typescript-eslint/eslint-plugin": "^8.62.0",
    "@typescript-eslint/parser": "^8.0.0",
    "dotenv": "^17.4.2",
    "eslint": "^10.6.0",
    "fast-check": "^4.8.0",
    "jest": "^29.7.0",
    "rimraf": "^6.0.0",
    "ts-jest": "^29.4.11",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "typedoc": "^0.28.19",
    "typescript": "^6.0.3"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
